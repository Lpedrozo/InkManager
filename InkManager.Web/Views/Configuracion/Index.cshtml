@{
    ViewData["Title"] = "Configuración";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Configuración</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Google Calendar -->
        <div class="bg-white rounded-xl shadow-sm p-6">
            <div class="flex items-center mb-4">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center mr-3">
                    <span class="text-xl">📅</span>
                </div>
                <h2 class="text-xl font-semibold text-gray-800">Google Calendar</h2>
            </div>

            <p class="text-gray-600 mb-4">
                Conecta tu cuenta de Google Calendar para sincronizar tus citas automáticamente.
            </p>

            @if (ViewBag.TieneCalendarConectado)
            {
                <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
                    <div class="flex items-center">
                        <span class="text-green-500 mr-2">✅</span>
                        <span class="text-green-700">Calendar conectado correctamente</span>
                    </div>
                    <p class="text-sm text-green-600 mt-1">Tus citas se sincronizarán automáticamente</p>
                </div>

                <form method="post" action="/configuracion/calendario/desconectar" onsubmit="return confirm('¿Estás seguro de que quieres desconectar tu calendario?')">
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg transition">
                        Desconectar Google Calendar
                    </button>
                </form>
            }
            else
            {
                <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 mb-4">
                    <div class="flex items-center">
                        <span class="text-yellow-500 mr-2">⚠️</span>
                        <span class="text-yellow-700">No has conectado tu calendario</span>
                    </div>
                    <p class="text-sm text-yellow-600 mt-1">Conecta tu cuenta para sincronizar tus citas</p>
                </div>

                <a href="/configuracion/calendario/conectar" class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition text-center">
                    Conectar Google Calendar
                </a>
            }

            <div class="mt-4 text-sm text-gray-500">
                <p>🔒 Tus credenciales se guardan de forma segura.</p>
                <p>🔄 Las citas se sincronizan automáticamente al crearse, modificarse o cancelarse.</p>
            </div>
        </div>

        <!-- Próximas funcionalidades -->
        <div class="bg-white rounded-xl shadow-sm p-6">
            <div class="flex items-center mb-4">
                <div class="w-10 h-10 bg-gray-100 rounded-full flex items-center justify-center mr-3">
                    <span class="text-xl">⚙️</span>
                </div>
                <h2 class="text-xl font-semibold text-gray-800">General</h2>
            </div>

            <div class="space-y-4">
                <div class="flex justify-between items-center py-2 border-b">
                    <span class="text-gray-700">Notificaciones por email</span>
                    <div class="relative inline-block w-10 mr-2 align-middle select-none">
                        <input type="checkbox" id="notificaciones" class="toggle-checkbox absolute block w-6 h-6 rounded-full bg-white border-4 appearance-none cursor-pointer" checked>
                        <label for="notificaciones" class="toggle-label block overflow-hidden h-6 rounded-full bg-gray-300 cursor-pointer"></label>
                    </div>
                </div>

                <div class="flex justify-between items-center py-2 border-b">
                    <span class="text-gray-700">Idioma</span>
                    <select class="rounded-lg border-gray-300 text-sm">
                        <option value="es" selected>Español</option>
                        <option value="en">English</option>
                    </select>
                </div>

                <div class="flex justify-between items-center py-2 border-b">
                    <span class="text-gray-700">Zona horaria</span>
                    <select class="rounded-lg border-gray-300 text-sm">
                        <option value="America/Madrid">Madrid (GMT+1)</option>
                        <option value="America/Mexico_City">Ciudad de México (GMT-6)</option>
                        <option value="America/Buenos_Aires">Buenos Aires (GMT-3)</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Información del sistema -->
    <div class="mt-6 bg-white rounded-xl shadow-sm p-6">
        <h3 class="text-lg font-semibold text-gray-800 mb-3">Información del sistema</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
            <div class="flex justify-between py-2 border-b">
                <span class="text-gray-600">Versión de la aplicación</span>
                <span class="font-medium">1.0.0</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-gray-600">Usuario</span>
                <span class="font-medium">@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-gray-600">Rol</span>
                <span class="font-medium">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
            </div>
            <div class="flex justify-between py-2 border-b">
                <span class="text-gray-600">Último acceso</span>
                <span class="font-medium">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        </div>
    </div>
</div>

<style>
    .toggle-checkbox:checked {
        right: 0;
        border-color: #7c3aed;
    }
    .toggle-checkbox:checked + .toggle-label {
        background-color: #7c3aed;
    }
    .toggle-checkbox {
        right: 0;
        transition: all 0.3s ease;
    }
</style>