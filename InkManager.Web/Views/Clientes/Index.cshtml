@{
    ViewData["Title"] = "Clientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div>
    <!-- Header responsive -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Gestión de Clientes</h1>
            <p class="text-gray-500 mt-1">Administra tus clientes y su historial</p>
        </div>
        <div class="flex gap-2 w-full sm:w-auto">
            <button onclick="abrirModalReporte()" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition flex items-center shadow-md justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                </svg>
                Reporte
            </button>
            <button onclick="abrirModalCrear()" class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-lg transition flex items-center shadow-md justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Nuevo Cliente
            </button>
        </div>
    </div>

    <!-- Buscador responsive -->
    <div class="bg-white rounded-xl shadow-sm p-4 mb-6">
        <div class="flex flex-col sm:flex-row gap-3">
            <div class="flex-1">
                <input type="text" id="searchInput" placeholder="Buscar por nombre, teléfono o email..."
                       class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500">
            </div>
            <button onclick="buscarClientes()" class="bg-gray-600 hover:bg-gray-700 text-white px-4 py-2 rounded-lg transition w-full sm:w-auto">
                Buscar
            </button>
        </div>
    </div>

    <!-- Tabla de clientes responsive -->
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="hidden md:block overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Cliente</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Teléfono</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Citas</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Gastado</th>
                        <th class="px-6 py-3 text-center text-xs font-medium text-gray-500 uppercase">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaClientes" class="divide-y divide-gray-200">
                    <tr><td colspan="6" class="text-center py-8 text-gray-500">Cargando clientes...</td></tr>
                </tbody>
            </table>
        </div>

        <div id="tarjetasClientes" class="md:hidden divide-y divide-gray-200">
            <div class="p-4 text-center text-gray-500">Cargando clientes...</div>
        </div>

        <div id="paginacion" class="px-4 md:px-6 py-4 border-t flex flex-col sm:flex-row justify-between items-center gap-3"></div>
    </div>
</div>

<!-- MODAL REPORTE -->
<div id="modalReporte" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
        <div class="p-4 border-b sticky top-0 bg-white rounded-t-xl">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">📊 Reporte de Clientes Nuevos</h2>
                <button onclick="cerrarModalReporte()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div class="p-5">
            <div class="mb-4">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Fecha Inicio</label>
                <input type="date" id="reporteFechaInicio" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500">
            </div>
            <div class="mb-4">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Fecha Fin</label>
                <input type="date" id="reporteFechaFin" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500">
            </div>
            <div class="mb-4">
                <label class="block text-sm font-semibold text-gray-700 mb-1">Opciones rápidas</label>
                <div class="flex flex-wrap gap-2">
                    <button type="button" onclick="setRangoReporte(7)" class="px-3 py-1 text-sm rounded-full bg-gray-100 hover:bg-purple-100 transition">Últimos 7 días</button>
                    <button type="button" onclick="setRangoReporte(30)" class="px-3 py-1 text-sm rounded-full bg-gray-100 hover:bg-purple-100 transition">Últimos 30 días</button>
                    <button type="button" onclick="setRangoReporte(90)" class="px-3 py-1 text-sm rounded-full bg-gray-100 hover:bg-purple-100 transition">Últimos 90 días</button>
                    <button type="button" onclick="setRangoReporte(365)" class="px-3 py-1 text-sm rounded-full bg-gray-100 hover:bg-purple-100 transition">Último año</button>
                </div>
            </div>

            <div id="reporteResumen" class="mt-4 p-3 bg-gray-50 rounded-lg hidden">
                <p class="text-sm text-gray-600" id="reporteTotalClientes"></p>
                <p class="text-sm text-gray-600" id="reporteTotalGastado"></p>
            </div>
        </div>
        <div class="p-4 border-t flex gap-2 bg-gray-50 rounded-b-xl">
            <button onclick="cerrarModalReporte()" class="flex-1 px-4 py-2 text-gray-600 hover:text-gray-800 transition font-medium">Cancelar</button>
            <button onclick="exportarReporte('csv')" class="flex-1 px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                CSV
            </button>
            <button onclick="exportarReporte('vcf')" class="flex-1 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                VCF
            </button>
        </div>
    </div>
</div>

<!-- MODAL CLIENTE -->
<div id="modalCliente" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md max-h-[90vh] overflow-y-auto">
        <div class="p-4 md:p-5 border-b sticky top-0 bg-white rounded-t-xl">
            <div class="flex justify-between items-center">
                <h2 id="modalTitulo" class="text-xl font-bold text-gray-800">👤 Nuevo Cliente</h2>
                <button onclick="cerrarModalCliente()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div class="p-4 md:p-5">
            <form id="formCliente" onsubmit="return false;">
                <input type="hidden" id="clienteId">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre completo <span class="text-red-500">*</span></label>
                    <input type="text" id="nombre" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="Ej: Juan Pérez" required>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Teléfono <span class="text-red-500">*</span></label>
                    <input type="tel" id="telefono" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="Ej: 600111222" required>
                    <p class="text-xs text-gray-400 mt-1">Único - Se usará para iniciar sesión</p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
                    <input type="email" id="email" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="cliente@ejemplo.com">
                    <p class="text-xs text-gray-400 mt-1">Opcional</p>
                </div>
                <div class="mb-4 bg-blue-50 p-3 rounded-lg text-xs text-blue-700">
                    ℹ️ La contraseña será generada automáticamente: <strong>Cliente123!</strong>
                </div>
            </form>
        </div>
        <div class="p-4 md:p-5 border-t flex justify-end space-x-3 bg-gray-50 rounded-b-xl">
            <button onclick="cerrarModalCliente()" class="px-4 py-2 text-gray-600 hover:text-gray-800 transition font-medium">Cancelar</button>
            <button onclick="guardarCliente()" id="btnGuardarCliente" class="px-4 py-2 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition font-medium">Guardar</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/toast.js"></script>
    <script>
        let paginaActual = 1;
        let clienteEditId = null;
        let reporteData = null;

        // ============================================
        // Reporte
        // ============================================
        window.abrirModalReporte = function() {
            const hoy = new Date();
            const hace30Dias = new Date();
            hace30Dias.setDate(hoy.getDate() - 30);

            document.getElementById('reporteFechaInicio').value = hace30Dias.toISOString().split('T')[0];
            document.getElementById('reporteFechaFin').value = hoy.toISOString().split('T')[0];

            document.getElementById('modalReporte').classList.remove('hidden');
            document.getElementById('modalReporte').classList.add('flex');
            document.getElementById('reporteResumen').classList.add('hidden');

            setTimeout(() => cargarResumenReporte(), 100);
        };

        window.cerrarModalReporte = function() {
            document.getElementById('modalReporte').classList.add('hidden');
            document.getElementById('modalReporte').classList.remove('flex');
        };

        window.setRangoReporte = function(dias) {
            const hoy = new Date();
            const fechaInicio = new Date();
            fechaInicio.setDate(hoy.getDate() - dias);

            document.getElementById('reporteFechaInicio').value = fechaInicio.toISOString().split('T')[0];
            document.getElementById('reporteFechaFin').value = hoy.toISOString().split('T')[0];
            cargarResumenReporte();
        };

        async function cargarResumenReporte() {
            const fechaInicio = document.getElementById('reporteFechaInicio').value;
            const fechaFin = document.getElementById('reporteFechaFin').value;
            if (!fechaInicio || !fechaFin) return;

            try {
                const response = await fetch(`/api/clientes/reporte/nuevos?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`);
                const result = await response.json();

                if (result.success && result.data) {
                    reporteData = result.data;
                    const totalClientes = result.data.length;
                    const totalGastado = result.data.reduce((sum, c) => sum + (c.totalGastado || 0), 0);

                    document.getElementById('reporteTotalClientes').textContent = `📊 Total clientes nuevos: ${totalClientes}`;
                    document.getElementById('reporteTotalGastado').textContent = `💰 Total gastado: $${totalGastado.toLocaleString()}`;
                    document.getElementById('reporteResumen').classList.remove('hidden');
                }
            } catch (error) {
                console.error('Error cargando resumen:', error);
            }
        }

        window.exportarReporte = async function(tipo) {
            const fechaInicio = document.getElementById('reporteFechaInicio').value;
            const fechaFin = document.getElementById('reporteFechaFin').value;

            if (!fechaInicio || !fechaFin) {
                showToast('Selecciona el rango de fechas', 'error');
                return;
            }

            const url = tipo === 'vcf'
                ? `/api/clientes/reporte/exportar-vcf?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`
                : `/api/clientes/reporte/exportar?fechaInicio=${fechaInicio}&fechaFin=${fechaFin}`;

            try {
                const response = await fetch(url);
                const blob = await response.blob();

                const downloadUrl = window.URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = downloadUrl;

                const fechaStr = new Date().toISOString().split('T')[0];
                const extension = tipo === 'vcf' ? 'vcf' : 'csv';
                a.download = `clientes_nuevos_${fechaInicio}_a_${fechaFin}_${fechaStr}.${extension}`;

                document.body.appendChild(a);
                a.click();
                window.URL.revokeObjectURL(downloadUrl);
                document.body.removeChild(a);

                showToast(`Reporte exportado como ${extension.toUpperCase()}`, 'success');
                cerrarModalReporte();
            } catch (error) {
                showToast('Error al exportar el reporte', 'error');
            }
        };

        document.getElementById('reporteFechaInicio')?.addEventListener('change', cargarResumenReporte);
        document.getElementById('reporteFechaFin')?.addEventListener('change', cargarResumenReporte);

        // ============================================
        // Cargar lista de clientes
        // ============================================
        async function cargarClientes(pagina = 1, search = '') {
            paginaActual = pagina;
            try {
                const response = await fetch(`/api/clientes?pagina=${pagina}&pageSize=10&search=${encodeURIComponent(search)}`);
                const result = await response.json();

                if (result.success) {
                    renderizarTabla(result.data.items);
                    renderizarTarjetas(result.data.items);
                    renderizarPaginacion(result.data);
                }
            } catch (error) {
                console.error('Error cargando clientes:', error);
            }
        }

        function renderizarTabla(clientes) {
            const tbody = document.getElementById('tablaClientes');
            if (!clientes || clientes.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center py-8 text-gray-500">No hay clientes registrados</td></tr>';
                return;
            }

            tbody.innerHTML = clientes.map(cliente => `
                <tr class="hover:bg-gray-50">
                    <td class="px-6 py-4">
                        <div class="flex items-center">
                            <div class="w-10 h-10 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-bold">
                                ${escapeHtml(cliente.nombre.charAt(0).toUpperCase())}
                            </div>
                            <div class="ml-3">
                                <p class="font-medium text-gray-900">${escapeHtml(cliente.nombre)}</p>
                                <p class="text-xs text-gray-500">Desde ${new Date(cliente.fechaRegistro).toLocaleDateString()}</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-gray-600">📱 ${escapeHtml(cliente.telefono)}</td>
                    <td class="px-6 py-4 text-gray-600">${cliente.email ? escapeHtml(cliente.email) : '—'}</td>
                    <td class="px-6 py-4 text-center">
                        <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">${cliente.totalCitas} citas</span>
                    </td>
                    <td class="px-6 py-4 font-medium text-green-600">$${cliente.totalGastado.toLocaleString()}</td>
                    <td class="px-6 py-4 text-center">
                        <button onclick='editarCliente(${JSON.stringify(cliente).replace(/'/g, "&#39;")})' class="text-blue-600 hover:text-blue-800 mr-3" title="Editar">✏️</button>
                        <button onclick="eliminarCliente(${cliente.id})" class="text-red-600 hover:text-red-800" title="Eliminar">🗑️</button>
                    </td>
                </tr>
            `).join('');
        }

        function renderizarTarjetas(clientes) {
            const container = document.getElementById('tarjetasClientes');
            if (!clientes || clientes.length === 0) {
                container.innerHTML = '<div class="p-4 text-center text-gray-500">No hay clientes registrados</div>';
                return;
            }

            container.innerHTML = clientes.map(cliente => `
                <div class="p-4 border-b hover:bg-gray-50">
                    <div class="flex items-start justify-between">
                        <div class="flex items-center">
                            <div class="w-12 h-12 rounded-full bg-purple-100 flex items-center justify-center text-purple-600 font-bold text-lg">
                                ${escapeHtml(cliente.nombre.charAt(0).toUpperCase())}
                            </div>
                            <div class="ml-3">
                                <p class="font-semibold text-gray-900">${escapeHtml(cliente.nombre)}</p>
                                <p class="text-sm text-gray-500">📱 ${escapeHtml(cliente.telefono)}</p>
                                ${cliente.email ? `<p class="text-sm text-gray-500">📧 ${escapeHtml(cliente.email)}</p>` : ''}
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="px-2 py-1 text-xs rounded-full bg-blue-100 text-blue-800">${cliente.totalCitas} citas</span>
                            <p class="text-sm font-semibold text-green-600 mt-1">$${cliente.totalGastado.toLocaleString()}</p>
                        </div>
                    </div>
                    <div class="flex justify-end mt-3 gap-2">
                        <button onclick='editarCliente(${JSON.stringify(cliente).replace(/'/g, "&#39;")})' class="text-blue-600 hover:text-blue-800 text-sm">✏️ Editar</button>
                        <button onclick="eliminarCliente(${cliente.id})" class="text-red-600 hover:text-red-800 text-sm">🗑️ Eliminar</button>
                    </div>
                </div>
            `).join('');
        }

        function renderizarPaginacion(data) {
            const container = document.getElementById('paginacion');
            if (data.totalPages <= 1) {
                container.innerHTML = '';
                return;
            }

            let html = `<div class="text-sm text-gray-500">Mostrando ${data.items.length} de ${data.totalCount} clientes</div>`;
            html += `<div class="flex space-x-2">`;

            if (data.hasPreviousPage) {
                html += `<button onclick="cargarClientes(${data.pageNumber - 1}, document.getElementById('searchInput').value)" class="px-3 py-1 border rounded hover:bg-gray-50">Anterior</button>`;
            }

            html += `<span class="px-3 py-1 bg-gray-100 rounded">${data.pageNumber} / ${data.totalPages}</span>`;

            if (data.hasNextPage) {
                html += `<button onclick="cargarClientes(${data.pageNumber + 1}, document.getElementById('searchInput').value)" class="px-3 py-1 border rounded hover:bg-gray-50">Siguiente</button>`;
            }

            html += `</div>`;
            container.innerHTML = html;
        }

        function buscarClientes() {
            const search = document.getElementById('searchInput').value;
            cargarClientes(1, search);
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // ============================================
        // Modal de cliente
        // ============================================
        window.abrirModalCrear = function() {
            clienteEditId = null;
            document.getElementById('modalTitulo').textContent = '👤 Nuevo Cliente';
            document.getElementById('formCliente').reset();
            document.getElementById('clienteId').value = '';
            const modal = document.getElementById('modalCliente');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        };

        window.editarCliente = function(cliente) {
            clienteEditId = cliente.id;
            document.getElementById('modalTitulo').textContent = '✏️ Editar Cliente';
            document.getElementById('clienteId').value = cliente.id;
            document.getElementById('nombre').value = cliente.nombre;
            document.getElementById('telefono').value = cliente.telefono;
            document.getElementById('email').value = cliente.email || '';
            const modal = document.getElementById('modalCliente');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        };

        window.cerrarModalCliente = function() {
            const modal = document.getElementById('modalCliente');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        };

        window.guardarCliente = async function() {
            const nombre = document.getElementById('nombre').value.trim();
            const telefono = document.getElementById('telefono').value.trim();
            const email = document.getElementById('email').value.trim();
            const clienteId = document.getElementById('clienteId').value;

            if (!nombre) { showToast('El nombre es requerido', 'error'); return; }
            if (!telefono) { showToast('El teléfono es requerido', 'error'); return; }

            const btn = document.getElementById('btnGuardarCliente');
            btn.disabled = true;
            btn.innerHTML = 'Guardando...';

            try {
                let response;
                if (clienteId) {
                    response = await fetch(`/api/clientes/${clienteId}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ nombre, telefono, email: email || null })
                    });
                } else {
                    response = await fetch('/api/clientes', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ nombre, telefono, email: email || null, password: null })
                    });
                }

                const result = await response.json();

                if (result.success) {
                    showToast(result.message, 'success');
                    cerrarModalCliente();
                    cargarClientes(paginaActual, document.getElementById('searchInput').value);
                } else {
                    showToast(result.message || 'Error al guardar', 'error');
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Guardar';
            }
        };

        window.eliminarCliente = async function(id) {
            const confirmed = confirm('¿Estás seguro de eliminar este cliente? Esta acción no se puede deshacer.');
            if (!confirmed) return;

            try {
                const response = await fetch(`/api/clientes/${id}`, { method: 'DELETE' });
                const result = await response.json();

                if (result.success) {
                    showToast('Cliente eliminado', 'success');
                    cargarClientes(paginaActual, document.getElementById('searchInput').value);
                } else {
                    showToast(result.message || 'Error al eliminar', 'error');
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
            }
        };

        // Inicializar
        cargarClientes();

        let searchTimeout;
        document.getElementById('searchInput').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => buscarClientes(), 500);
        });
    </script>
}