@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>InkManager - Iniciar Sesión</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .toast {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
            animation: slideIn 0.3s ease-out;
        }

        @@keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .toast-exit {
            animation: slideOut 0.3s ease-in forwards;
        }

        @@keyframes slideOut {
            from {
                transform: translateX(0);
                opacity: 1;
            }

            to {
                transform: translateX(100%);
                opacity: 0;
            }
        }

        .checkbox-custom {
            width: 1.1rem;
            height: 1.1rem;
            border-radius: 0.25rem;
            border: 2px solid #cbd5e1;
            cursor: pointer;
        }

            .checkbox-custom:checked {
                background-color: #8b5cf6;
                border-color: #8b5cf6;
            }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <div id="toastContainer" class="fixed bottom-4 right-4 z-50"></div>

    <div id="app" class="w-full max-w-md">
        <!-- Pantalla de Login -->
        <div id="loginScreen" class="bg-white rounded-2xl shadow-2xl overflow-hidden">
            <div class="bg-gradient-to-r from-purple-600 to-indigo-600 p-6 text-center">
                <div class="text-5xl mb-2">🖤</div>
                <h1 class="text-2xl font-bold text-white">InkManager</h1>
                <p class="text-purple-200 text-sm mt-1">Gestión profesional de tatuajes</p>
            </div>

            <div class="p-8">
                <h2 class="text-2xl font-semibold text-gray-800 text-center mb-6">Iniciar Sesión</h2>

                <form id="loginForm" onsubmit="return false;">
                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-medium mb-2">Correo o Teléfono</label>
                        <input type="text" id="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent" placeholder="usuario@ejemplo.com o 600111222" required>
                    </div>

                    <div class="mb-4">
                        <label class="block text-gray-700 text-sm font-medium mb-2">Contraseña</label>
                        <input type="password" id="password" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent" placeholder="••••••••" required>
                    </div>

                    <div class="mb-6 flex items-center justify-between">
                        <label class="flex items-center cursor-pointer">
                            <input type="checkbox" id="rememberMe" class="checkbox-custom" checked>
                            <span class="ml-2 text-sm text-gray-600">Recordarme por 7 días</span>
                        </label>
                        <a href="#" class="text-sm text-purple-600 hover:text-purple-700">¿Olvidaste tu contraseña?</a>
                    </div>

                    <button type="submit" onclick="login()" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-semibold py-2 rounded-lg hover:opacity-90 transition flex items-center justify-center">
                        <span id="loginBtnText">Ingresar</span>
                        <span id="loginSpinner" class="hidden ml-2">
                            <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                        </span>
                    </button>
                </form>

                <div class="mt-6 text-center text-sm text-gray-500">
                    <p>Credenciales de prueba:</p>
                    <p class="text-xs mt-1">🎨 Juan (artista): juan.perez@inkmaster.com / Password123!</p>
                    <p class="text-xs">🤝 Pedro (asistente): pedro.asistente@inkmaster.com / Password123!</p>
                    <p class="text-xs">👑 Admin: admin@inkmanager.com / Password123!</p>
                </div>
            </div>
        </div>

        <!-- Pantalla de Selección -->
        <div id="selectionScreen" class="bg-white rounded-2xl shadow-2xl overflow-hidden hidden">
            <div class="bg-gradient-to-r from-purple-600 to-indigo-600 p-6 text-center">
                <div class="text-4xl mb-1">👋</div>
                <h2 class="text-xl font-bold text-white" id="userName"></h2>
                <p class="text-purple-200 text-sm" id="userEmail"></p>
            </div>

            <div class="p-8">
                <p class="text-gray-600 text-center mb-6" id="selectionMessage"></p>

                <div id="rolesSection" class="mb-6 hidden">
                    <label class="block text-gray-700 text-sm font-medium mb-3">Tu rol:</label>
                    <div id="rolesContainer" class="grid grid-cols-2 gap-3"></div>
                </div>

                <div id="estudiosSection" class="mb-6 hidden">
                    <label class="block text-gray-700 text-sm font-medium mb-3">Estudio:</label>
                    <div id="estudiosContainer" class="space-y-2"></div>
                </div>

                <div id="artistasSection" class="mb-6 hidden">
                    <label class="block text-gray-700 text-sm font-medium mb-3">Artista al que asistes:</label>
                    <div id="artistasContainer" class="space-y-2"></div>
                </div>

                <div class="flex items-center mb-6">
                    <input type="checkbox" id="rememberMeSelect" class="checkbox-custom" checked>
                    <label class="ml-2 text-sm text-gray-600">Recordarme por 7 días</label>
                </div>

                <button onclick="confirmSelection()" id="confirmBtn" class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 text-white font-semibold py-2 rounded-lg hover:opacity-90 transition disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                    Continuar
                </button>

                <button onclick="backToLogin()" class="w-full mt-3 text-gray-500 text-sm hover:text-gray-700 transition">
                    ← Volver al inicio
                </button>
            </div>
        </div>
    </div>

    <script>
        let userData = null;
        let selectedRolId = null;
        let selectedEstudioId = null;
        let selectedArtistaId = null;
        let availableRoles = [];
        let availableEstudios = [];
        let availableArtistas = [];

        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer');
            const toast = document.createElement('div');
            toast.className = `toast mb-3 p-4 rounded-lg shadow-lg flex items-center min-w-[300px] ${type === 'success' ? 'bg-green-500' : 'bg-red-500'} text-white`;
            toast.innerHTML = `
                <span class="mr-3">${type === 'success' ? '✅' : '❌'}</span>
                <span class="flex-1">${message}</span>
                <button onclick="this.parentElement.remove()" class="ml-3 hover:opacity-75">✕</button>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.add('toast-exit');
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        async function login() {
            const email = document.getElementById('email').value.trim();
            const password = document.getElementById('password').value;
            const rememberMe = document.getElementById('rememberMe').checked;

            if (!email || !password) {
                showToast('Por favor completa todos los campos', 'error');
                return;
            }

            const btn = document.getElementById('loginBtnText');
            const spinner = document.getElementById('loginSpinner');

            btn.classList.add('opacity-50');
            spinner.classList.remove('hidden');

            try {
                const response = await fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password, rememberMe })
                });

                const result = await response.json();

                if (result.success) {
                    if (result.redirectUrl) {
                        window.location.href = result.redirectUrl;
                    } else if (result.data?.availableRoles || result.data?.artistasAsistidos) {
                        userData = result.data;
                        showSelectionScreen();
                    } else if (result.data?.redirectUrl) {
                        window.location.href = result.data.redirectUrl;
                    } else {
                        showToast(result.data?.message || 'Login exitoso', 'success');
                        setTimeout(() => {
                            window.location.href = '/dashboard';
                        }, 1000);
                    }
                } else {
                    showToast(result.message || 'Credenciales incorrectas', 'error');
                }
            } catch (error) {
                showToast('Error de conexión con el servidor', 'error');
            } finally {
                btn.classList.remove('opacity-50');
                spinner.classList.add('hidden');
            }
        }

        function showSelectionScreen() {
            document.getElementById('loginScreen').classList.add('hidden');
            document.getElementById('selectionScreen').classList.remove('hidden');

            document.getElementById('userName').textContent = userData.user.nombre;
            document.getElementById('userEmail').textContent = userData.user.email;

            availableRoles = userData.availableRoles || [];
            availableEstudios = userData.availableEstudios || [];
            availableArtistas = userData.artistasAsistidos || [];

            const tieneMultiplesRoles = availableRoles.length > 1;
            const tieneMultiplesEstudios = availableEstudios.length > 1;
            const esAsistente = availableRoles.some(r => r.nombre === 'asistente') && availableArtistas.length > 0;
            const esArtistaConMultiplesEstudios = availableRoles.some(r => r.nombre === 'artista') && availableEstudios.length > 1;

            document.getElementById('rolesSection').classList.toggle('hidden', !tieneMultiplesRoles);
            document.getElementById('estudiosSection').classList.toggle('hidden', !esArtistaConMultiplesEstudios);
            document.getElementById('artistasSection').classList.toggle('hidden', !esAsistente);

            let message = '';
            if (esArtistaConMultiplesEstudios) message = 'Selecciona el estudio donde trabajarás';
            else if (esAsistente) message = 'Selecciona el artista al que asistirás';
            else if (tieneMultiplesRoles) message = 'Selecciona el rol con el que quieres acceder';

            document.getElementById('selectionMessage').textContent = message;

            if (tieneMultiplesRoles) {
                const rolesContainer = document.getElementById('rolesContainer');
                rolesContainer.innerHTML = '';
                availableRoles.forEach(rol => {
                    const icon = getRolIcon(rol.nombre);
                    const card = document.createElement('div');
                    card.className = `p-3 border-2 rounded-xl cursor-pointer transition text-center role-card ${selectedRolId === rol.rolId ? 'border-purple-600 bg-purple-50' : 'border-gray-200 hover:border-purple-300'}`;
                    card.onclick = () => selectRol(rol.rolId, card);
                    card.innerHTML = `
                        <div class="text-2xl mb-1">${icon}</div>
                        <div class="font-semibold text-gray-800">${capitalize(rol.nombre)}</div>
                        <div class="text-xs text-gray-500 mt-1">${rol.descripcion || ''}</div>
                    `;
                    rolesContainer.appendChild(card);
                });
            } else if (availableRoles.length === 1) {
                selectedRolId = availableRoles[0].rolId;
            }

            if (esArtistaConMultiplesEstudios) renderEstudios();
            if (esAsistente) renderArtistas();

            enableConfirmButton();
        }

        function selectRol(rolId, card) {
            selectedRolId = rolId;
            document.querySelectorAll('.role-card').forEach(c => {
                c.classList.remove('border-purple-600', 'bg-purple-50');
                c.classList.add('border-gray-200');
            });
            card.classList.add('border-purple-600', 'bg-purple-50');
            card.classList.remove('border-gray-200');
            enableConfirmButton();
        }

        function selectEstudio(estudioId) {
            selectedEstudioId = estudioId;
            renderEstudios();
            enableConfirmButton();
        }

        function selectArtista(artistaId, estudioId) {
            selectedArtistaId = artistaId;
            selectedEstudioId = estudioId;
            renderArtistas();
            enableConfirmButton();
        }

        function renderEstudios() {
            const container = document.getElementById('estudiosContainer');
            container.innerHTML = '';
            availableEstudios.forEach(estudio => {
                const isSelected = selectedEstudioId === estudio.estudioId;
                const div = document.createElement('div');
                div.className = `flex items-center p-3 border rounded-xl cursor-pointer transition ${isSelected ? 'border-purple-600 bg-purple-50' : 'border-gray-200 hover:border-purple-300'}`;
                div.onclick = () => selectEstudio(estudio.estudioId);
                div.innerHTML = `
                    <div class="w-5 h-5 rounded-full border-2 mr-3 flex items-center justify-center ${isSelected ? 'border-purple-600 bg-purple-600' : 'border-gray-400'}">
                        ${isSelected ? '<div class="w-2 h-2 bg-white rounded-full"></div>' : ''}
                    </div>
                    <div class="flex-1">
                        <div class="font-semibold text-gray-800">${estudio.nombre}</div>
                        <div class="text-xs text-gray-500">${estudio.direccion}</div>
                        <div class="text-xs text-purple-600 mt-1">${estudio.rolEnEstudio || ''}</div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function renderArtistas() {
            const container = document.getElementById('artistasContainer');
            container.innerHTML = '';
            availableArtistas.forEach(artista => {
                const isSelected = selectedArtistaId === artista.artistaId;
                const div = document.createElement('div');
                div.className = `flex items-center p-3 border rounded-xl cursor-pointer transition ${isSelected ? 'border-purple-600 bg-purple-50' : 'border-gray-200 hover:border-purple-300'}`;
                div.onclick = () => selectArtista(artista.artistaId, artista.estudioId);
                div.innerHTML = `
                    <div class="w-5 h-5 rounded-full border-2 mr-3 flex items-center justify-center ${isSelected ? 'border-purple-600 bg-purple-600' : 'border-gray-400'}">
                        ${isSelected ? '<div class="w-2 h-2 bg-white rounded-full"></div>' : ''}
                    </div>
                    <div class="flex-1">
                        <div class="font-semibold text-gray-800">${artista.nombre}</div>
                        <div class="text-xs text-gray-500">${artista.estudioNombre}</div>
                    </div>
                `;
                container.appendChild(div);
            });
        }

        function enableConfirmButton() {
            const btn = document.getElementById('confirmBtn');
            let enabled = true;
            if (availableRoles.length > 1 && !selectedRolId) enabled = false;
            if (availableEstudios.length > 1 && !selectedEstudioId) enabled = false;
            if (availableArtistas.length > 0 && !selectedArtistaId) enabled = false;
            btn.disabled = !enabled;
        }

        async function confirmSelection() {
            const rememberMe = document.getElementById('rememberMeSelect').checked;

            const payload = {
                usuarioId: userData.user.id,
                rolId: selectedRolId,
                rememberMe: rememberMe
            };

            if (selectedEstudioId) payload.estudioId = selectedEstudioId;
            if (selectedArtistaId) payload.artistaId = selectedArtistaId;

            const btn = document.getElementById('confirmBtn');
            btn.disabled = true;
            btn.innerHTML = '<span class="inline-block animate-spin mr-2">⏳</span> Procesando...';

            try {
                const response = await fetch('/api/auth/select-role-estudio', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                const result = await response.json();

                if (result.success) {
                    showToast(result.message, 'success');
                            localStorage.setItem('session', JSON.stringify({
            usuarioId: result.session.usuarioId,
            nombre: result.session.nombre,
            email: result.session.email,
            rol: result.session.rolNombre,
            artistaId: result.session.artistaId || result.session.usuarioId,
            artistaNombre: result.session.artistaNombre || result.session.nombre,
            estudioId: result.session.estudioId,
            estudioNombre: result.session.estudioNombre
        }));
                    window.location.href = result.redirectUrl || '/dashboard';
                } else {
                    showToast(result.message, 'error');
                    btn.disabled = false;
                    btn.innerHTML = 'Continuar';
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
                btn.disabled = false;
                btn.innerHTML = 'Continuar';
            }
        }

        function backToLogin() {
            document.getElementById('selectionScreen').classList.add('hidden');
            document.getElementById('loginScreen').classList.remove('hidden');
            selectedRolId = null;
            selectedEstudioId = null;
            selectedArtistaId = null;
            userData = null;
            document.getElementById('email').value = '';
            document.getElementById('password').value = '';
        }

        function getRolIcon(rol) {
            const icons = { 'admin': '👑', 'artista': '🎨', 'asistente': '🤝', 'cliente': '👤' };
            return icons[rol] || '🔘';
        }

        function capitalize(str) {
            return str.charAt(0).toUpperCase() + str.slice(1);
        }
    </script>
</body>
</html>