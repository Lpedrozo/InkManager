@{
    ViewData["Title"] = "Mis Citas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mx-auto px-4 py-6">
    <!-- Header responsive -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Gestión de Citas</h1>
            <p class="text-gray-500 mt-1">Agenda y gestiona tus citas de tatuajes</p>
        </div>
        <button onclick="abrirModalCrear()" class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-4 rounded-lg transition flex items-center shadow-md w-full sm:w-auto justify-center">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nueva Cita
        </button>
    </div>

    <!-- Calendario (responsive) -->
    <div class="bg-white rounded-xl shadow-sm p-4 md:p-6 mb-6 overflow-x-auto">
        <div id="calendar"></div>
    </div>

    <!-- Listado de citas -->
    <div class="bg-white rounded-xl shadow-sm overflow-hidden">
        <div class="px-4 md:px-6 py-4 border-b border-gray-200 bg-gray-50">
            <h2 class="text-lg font-semibold text-gray-800">Próximas Citas</h2>
        </div>
        <div id="listaCitas" class="divide-y divide-gray-200">
            <div class="p-8 text-center text-gray-500">Cargando citas...</div>
        </div>
    </div>
</div>

<!-- MODAL CREAR CITA -->
<div id="modalCrear" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-6xl max-h-[90vh] overflow-y-auto">
        <div class="p-4 md:p-5 border-b sticky top-0 bg-white z-10 rounded-t-xl">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">📅 Agendar Nueva Cita</h2>
                <button onclick="cerrarModalCrear()" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <div class="p-4 md:p-6">
            <form id="formCita" onsubmit="return false;">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Columna izquierda -->
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">
                                Cliente <span class="text-red-500">*</span>
                            </label>
                            <div class="flex gap-2">
                                <select id="clienteId" class="flex-1 rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" required>
                                    <option value="">-- Seleccionar cliente --</option>
                                </select>
                                <button type="button" onclick="abrirModalClienteRapido()"
                                        class="bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg transition flex items-center"
                                        title="Nuevo Cliente">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">
                                Estudio <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="estudioNombre" class="w-full rounded-lg border-gray-300 bg-gray-100" readonly disabled>
                            <input type="hidden" id="estudioId">
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">
                                Artista <span class="text-red-500">*</span>
                            </label>
                            <input type="text" id="artistaNombre" class="w-full rounded-lg border-gray-300 bg-gray-100" readonly disabled>
                            <input type="hidden" id="artistaId">
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">
                                    Fecha <span class="text-red-500">*</span>
                                </label>
                                <input type="date" id="fechaCita" required>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">
                                    Hora <span class="text-red-500">*</span>
                                </label>
                                <select id="horaCita" required disabled>
                                    <option value="">Primero selecciona fecha</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Duración</label>
                            <select id="duracion">
                                <option value="1">1 hora</option>
                                <option value="2">2 horas</option>
                                <option value="3">3 horas</option>
                                <option value="4">4 horas</option>
                                <option value="5">5 horas</option>
                                <option value="6">6 horas</option>
                            </select>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Precio Total</label>
                                <div class="input-with-icon">
                                    <span>$</span>
                                    <input type="number" step="0.01" id="precioTotal" placeholder="0.00">
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Adelanto</label>
                                <div class="input-with-icon">
                                    <span>$</span>
                                    <input type="number" step="0.01" id="adelanto" placeholder="0.00">
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-semibold text-gray-700 mb-1">Tamaño (cm)</label>
                                <input type="number" step="0.1" id="tamanioCm" placeholder="0.0">
                            </div>
                            <div class="flex items-end pb-2">
                                <label class="flex items-center cursor-pointer">
                                    <input type="checkbox" id="requiereRecordatorio" class="w-4 h-4 mr-2" checked>
                                    <span class="text-sm text-gray-700">📧 Recordatorio</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Notas Internas</label>
                            <textarea id="notasInternas" rows="3" placeholder="Detalles del diseño, referencias, instrucciones especiales..."></textarea>
                        </div>

                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-1">Imagen de Referencia</label>
                            <div class="flex flex-col sm:flex-row gap-2">
                                <input type="file" id="fotoReferencia" accept="image/*" class="flex-1 rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500">
                                <div id="previewImagen" class="hidden mt-2">
                                    <img id="previewImg" class="w-32 h-32 object-cover rounded-lg border shadow-sm">
                                    <button type="button" onclick="limpiarImagen()" class="text-red-500 text-sm mt-1 hover:text-red-700">✕ Eliminar</button>
                                </div>
                            </div>
                            <p class="text-xs text-gray-400 mt-1">Sube una imagen de referencia del diseño (opcional)</p>
                        </div>
                    </div>

                    <!-- Columna derecha - Zonas del cuerpo -->
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">
                            📍 Zona del Cuerpo <span class="text-red-500">*</span>
                        </label>

                        <div class="flex flex-wrap gap-2 mb-4">
                            <button type="button" onclick="filtrarZonasPorCategoria('todas')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-purple-600 text-white transition-all shadow-sm">Todas</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Cabeza')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">👤 Cabeza</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Torso')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">👕 Torso</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Brazo')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">💪 Brazos</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Mano')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">🖐️ Manos</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Pierna')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">🦵 Piernas</button>
                            <button type="button" onclick="filtrarZonasPorCategoria('Pie')" class="categoria-btn px-3 py-1.5 text-sm rounded-full bg-gray-100 text-gray-700 hover:bg-purple-100 transition-all">🦶 Pies</button>
                        </div>

                        <div id="zonasGrid" class="grid grid-cols-2 gap-3 max-h-80 overflow-y-auto p-2 bg-gray-50 rounded-lg border border-gray-200">
                            <div class="col-span-2 text-center text-gray-500 py-8">Cargando zonas...</div>
                        </div>

                        <div id="zonaSeleccionada" class="mt-4 p-3 bg-purple-50 rounded-lg hidden border border-purple-200">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center">
                                    <span class="text-xl mr-2">📍</span>
                                    <div>
                                        <span class="text-sm font-medium text-purple-800">Zona seleccionada:</span>
                                        <span id="zonaNombre" class="text-sm text-purple-600 font-medium ml-1"></span>
                                    </div>
                                </div>
                                <button onclick="limpiarZonaSeleccionada()" class="text-purple-400 hover:text-purple-600 transition">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        <input type="hidden" id="zonaCuerpoId">
                    </div>
                </div>
            </form>
        </div>

        <div class="p-4 md:p-5 border-t flex justify-end space-x-3 bg-gray-50 rounded-b-xl">
            <button onclick="cerrarModalCrear()" class="px-4 py-2 text-gray-600 hover:text-gray-800 transition font-medium">Cancelar</button>
            <button onclick="guardarCita()" id="btnGuardar" class="btn-primary px-4 py-2 text-white rounded-lg transition flex items-center font-medium shadow-sm">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Guardar Cita
            </button>
        </div>
    </div>
</div>

<!-- MODAL CLIENTE RÁPIDO -->
<div id="modalClienteRapido" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-[60] p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-md">
        <div class="p-4 border-b sticky top-0 bg-white rounded-t-xl">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">👤 Nuevo Cliente Rápido</h2>
                <button onclick="cerrarModalClienteRapido()" class="text-gray-400 hover:text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div class="p-5">
            <form id="formClienteRapido" onsubmit="return false;">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre completo <span class="text-red-500">*</span></label>
                    <input type="text" id="nombreRapido" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="Ej: Juan Pérez" required>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Teléfono <span class="text-red-500">*</span></label>
                    <input type="tel" id="telefonoRapido" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="Ej: 600111222" required>
                    <p class="text-xs text-gray-400 mt-1">Se usará como identificador único</p>
                </div>
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Email</label>
                    <input type="email" id="emailRapido" class="w-full rounded-lg border-gray-300 focus:border-purple-500 focus:ring-purple-500" placeholder="cliente@ejemplo.com (opcional)">
                </div>
                <div class="bg-blue-50 p-3 rounded-lg text-xs text-blue-700">
                    ℹ️ La contraseña será generada automáticamente: <strong>Cliente123!</strong>
                </div>
            </form>
        </div>
        <div class="p-4 border-t flex justify-end space-x-3 bg-gray-50 rounded-b-xl">
            <button onclick="cerrarModalClienteRapido()" class="px-4 py-2 text-gray-600 hover:text-gray-800 transition">Cancelar</button>
            <button onclick="guardarClienteRapido()" id="btnGuardarRapido" class="px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg transition">Crear Cliente</button>
        </div>
    </div>
</div>

<!-- MODAL DETALLE CITA -->
<div id="modalDetalle" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50 p-4">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-2xl max-h-[90vh] overflow-y-auto">
        <div class="p-4 md:p-5 border-b sticky top-0 bg-white z-10 rounded-t-xl">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800">📋 Detalle de Cita</h2>
                <button onclick="cerrarModalDetalle()" class="text-gray-400 hover:text-gray-600 transition">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>
        <div id="detalleContent" class="p-4 md:p-6">
            <div class="text-center py-8">Cargando detalles...</div>
        </div>
        <div class="p-4 md:p-5 border-t flex justify-end space-x-3 bg-gray-50 rounded-b-xl">
            <button onclick="cerrarModalDetalle()" class="px-4 py-2 text-gray-600 hover:text-gray-800 transition font-medium">Cerrar</button>
            <button id="btnCambiarEstado" class="px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition font-medium hidden">Cambiar Estado</button>
        </div>
    </div>
</div>

@section Scripts {
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/es.js'></script>
    <script src="~/js/toast.js"></script>

    <script>
        let calendar = null;
        let zonasData = [];
        let categoriaActual = 'todas';
        let selectedZonaId = null;
        let currentCitaId = null;
        let clienteRapidoCallback = null;

        // ============================================
        // Modal Cliente Rápido
        // ============================================
        window.abrirModalClienteRapido = function(callback) {
            clienteRapidoCallback = callback;
            document.getElementById('modalClienteRapido').classList.remove('hidden');
            document.getElementById('modalClienteRapido').classList.add('flex');
            document.getElementById('formClienteRapido').reset();
        };

        window.cerrarModalClienteRapido = function() {
            document.getElementById('modalClienteRapido').classList.add('hidden');
            document.getElementById('modalClienteRapido').classList.remove('flex');
        };

        window.guardarClienteRapido = async function() {
            const nombre = document.getElementById('nombreRapido').value.trim();
            const telefono = document.getElementById('telefonoRapido').value.trim();
            const email = document.getElementById('emailRapido').value.trim();

            if (!nombre) { showToast('El nombre es requerido', 'error'); return; }
            if (!telefono) { showToast('El teléfono es requerido', 'error'); return; }

            const btn = document.getElementById('btnGuardarRapido');
            btn.disabled = true;
            btn.innerHTML = 'Creando...';

            try {
                const response = await fetch('/api/clientes/rapido', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, telefono, email: email || null })
                });
                const result = await response.json();

                if (result.success) {
                    showToast('Cliente creado exitosamente', 'success');
                    cerrarModalClienteRapido();
                    await cargarClientes();
                    const select = document.getElementById('clienteId');
                    select.value = result.data.id;
                    if (clienteRapidoCallback) {
                        clienteRapidoCallback(result.data);
                        clienteRapidoCallback = null;
                    }
                } else {
                    showToast(result.message || 'Error al crear cliente', 'error');
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Crear Cliente';
            }
        };

                // ============================================
        // Obtener usuario actual (desde cookie)
        // ============================================
        async function cargarUsuarioActual() {
            try {
                console.log('Cargando usuario actual...');
                const response = await fetch('/api/auth/me');
                const result = await response.json();
                console.log('Respuesta de /api/auth/me:', result);

                if (result.success) {
                    const user = result.data;

                    // Verificar que los elementos existan antes de asignar valores
                    const artistaNombreInput = document.getElementById('artistaNombre');
                    const artistaIdInput = document.getElementById('artistaId');
                    const estudioNombreInput = document.getElementById('estudioNombre');
                    const estudioIdInput = document.getElementById('estudioId');

                    console.log('Elementos encontrados:', {
                        artistaNombre: !!artistaNombreInput,
                        artistaId: !!artistaIdInput,
                        estudioNombre: !!estudioNombreInput,
                        estudioId: !!estudioIdInput
                    });

                    if (artistaNombreInput) {
                        artistaNombreInput.value = user.artistaNombre || user.nombre || '';
                        console.log('artistaNombre asignado:', artistaNombreInput.value);
                    }
                    if (artistaIdInput) artistaIdInput.value = user.artistaId || user.usuarioId || '';
                    if (estudioNombreInput) estudioNombreInput.value = user.estudioNombre || '';
                    if (estudioIdInput) estudioIdInput.value = user.estudioId || '';

                    // Actualizar sidebar
                    const userNameNav = document.getElementById('userNameNav');
                    const userRolNav = document.getElementById('userRolNav');
                    if (userNameNav) userNameNav.textContent = user.nombre || 'Usuario';
                    if (userRolNav) userRolNav.textContent = user.rol || 'Usuario';
                } else {
                    console.error('Error en la respuesta:', result);
                }
            } catch (error) {
                console.error('Error cargando usuario:', error);
            }
        }
        // ============================================
        // Inicialización
        // ============================================
                document.addEventListener('DOMContentLoaded', function() {
            console.log('DOM cargado, inicializando...');
            inicializarCalendario();
            cargarClientes();

            // Pequeño retraso para asegurar que el modal esté listo si se abre
            setTimeout(() => {
                cargarUsuarioActual();
            }, 100);

            cargarZonasCuerpo();
            cargarProximasCitas();
        });

        // ============================================
        // Calendario
        // ============================================
        function inicializarCalendario() {
            const calendarEl = document.getElementById('calendar');
            calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                locale: 'es',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                events: async function(fetchInfo, successCallback) {
                    try {
                        const response = await fetch(`/api/citas?fechaInicio=${fetchInfo.start.toISOString()}&fechaFin=${fetchInfo.end.toISOString()}`);
                        const result = await response.json();
                        if (result.success) {
                            const eventos = result.data.items.map(cita => ({
                                id: cita.id,
                                title: `${cita.clienteNombre} - $${cita.precioTotal}`,
                                start: cita.fechaHoraInicio,
                                end: cita.fechaHoraFin,
                                backgroundColor: getColorPorEstado(cita.estado),
                                borderColor: getColorPorEstado(cita.estado)
                            }));
                            successCallback(eventos);
                        } else successCallback([]);
                    } catch (error) { successCallback([]); }
                },
                eventClick: function(info) { verDetalleCita(info.event.id); },
                height: 'auto',
                responsive: true
            });
            calendar.render();
        }

        function getColorPorEstado(estado) {
            const colores = { 'pendiente': '#F59E0B', 'confirmada': '#3B82F6', 'en_curso': '#8B5CF6', 'completada': '#10B981', 'cancelada': '#EF4444' };
            return colores[estado] || '#6B7280';
        }

        // ============================================
        // Cargar datos
        // ============================================
        async function cargarClientes() {
            try {
                const response = await fetch('/api/clientes?pagina=1&pageSize=100');
                const result = await response.json();
                if (result.success && result.data && result.data.items) {
                    const select = document.getElementById('clienteId');
                    select.innerHTML = '<option value="">-- Seleccionar cliente --</option>';
                    result.data.items.forEach(cliente => {
                        const option = document.createElement('option');
                        option.value = cliente.id;
                        option.textContent = `${cliente.nombre} - ${cliente.telefono}`;
                        select.appendChild(option);
                    });
                }
            } catch (error) {
                console.error('Error cargando clientes:', error);
            }
        }

        async function cargarZonasCuerpo() {
            try {
                const response = await fetch('/api/zonas-cuerpo');
                const result = await response.json();
                if (result.success && result.data.length > 0) {
                    zonasData = result.data;
                    filtrarZonasPorCategoria('todas');
                } else {
                    document.getElementById('zonasGrid').innerHTML = '<div class="col-span-2 text-center text-gray-500 py-8">No hay zonas disponibles</div>';
                }
            } catch (error) {
                console.error(error);
                document.getElementById('zonasGrid').innerHTML = '<div class="col-span-2 text-center text-red-500 py-8">Error al cargar zonas</div>';
            }
        }

        // ============================================
        // Filtrado de zonas
        // ============================================
        window.filtrarZonasPorCategoria = function(categoria) {
            categoriaActual = categoria;

            document.querySelectorAll('.categoria-btn').forEach(btn => {
                const btnText = btn.textContent.trim().replace(/[^a-zA-ZáéíóúÁÉÍÓÚ]/g, '');
                const categoriaBtn = categoria === 'todas' ? 'Todas' : categoria;

                if ((categoria === 'todas' && btnText === 'Todas') || btnText === categoriaBtn) {
                    btn.classList.remove('bg-gray-100', 'text-gray-700', 'hover:bg-purple-100');
                    btn.classList.add('bg-purple-600', 'text-white');
                } else {
                    btn.classList.remove('bg-purple-600', 'text-white');
                    btn.classList.add('bg-gray-100', 'text-gray-700', 'hover:bg-purple-100');
                }
            });

            const zonasFiltradas = categoria === 'todas' ? zonasData : zonasData.filter(z => z.categoria === categoria);
            const container = document.getElementById('zonasGrid');

            if (zonasFiltradas.length === 0) {
                container.innerHTML = '<div class="col-span-2 text-center text-gray-500 py-8">No hay zonas en esta categoría</div>';
                return;
            }

            const iconos = { 'Cabeza': '👤', 'Torso': '👕', 'Brazo': '💪', 'Mano': '🖐️', 'Pierna': '🦵', 'Pie': '🦶' };

            container.innerHTML = zonasFiltradas.map(zona => `
                <div onclick="seleccionarZona(${zona.id}, '${zona.nombre.replace(/'/g, "\\'")}')"
                     class="p-3 border rounded-lg cursor-pointer transition-all hover:border-purple-400 hover:bg-purple-50 hover:shadow-sm text-center">
                    <div class="text-2xl mb-1">${iconos[zona.categoria] || '📍'}</div>
                    <div class="text-sm font-medium text-gray-700">${zona.nombre}</div>
                </div>
            `).join('');
        };

        window.seleccionarZona = function(id, nombre) {
            selectedZonaId = id;
            document.getElementById('zonaCuerpoId').value = id;
            document.getElementById('zonaNombre').textContent = nombre;
            document.getElementById('zonaSeleccionada').classList.remove('hidden');
            showToast(`Zona seleccionada: ${nombre}`, 'success');
        };

        window.limpiarZonaSeleccionada = function() {
            selectedZonaId = null;
            document.getElementById('zonaCuerpoId').value = '';
            document.getElementById('zonaSeleccionada').classList.add('hidden');
        };

        // ============================================
        // Horarios
        // ============================================
        document.getElementById('fechaCita')?.addEventListener('change', cargarHorarios);

        async function cargarHorarios() {
            const artistaId = document.getElementById('artistaId').value;
            const fecha = document.getElementById('fechaCita').value;
            if (!artistaId || !fecha) return;

            const horaSelect = document.getElementById('horaCita');
            horaSelect.disabled = true;
            horaSelect.innerHTML = '<option value="">Cargando horarios...</option>';

            try {
                const response = await fetch(`/api/horarios-disponibles?artistaId=${artistaId}&fecha=${fecha}`);
                const result = await response.json();

                if (result.success && result.data.length > 0) {
                    horaSelect.innerHTML = '<option value="">-- Seleccionar hora --</option>';
                    result.data.forEach(slot => {
                        const option = document.createElement('option');
                        // Extraer solo la hora en formato HH:MM del Display
                        // El Display viene como "09:00 - 10:00"
                        const horaDisplay = slot.display.split(' - ')[0];
                        option.value = horaDisplay; // Esto será "09:00"
                        option.textContent = slot.display; // Esto será "09:00 - 10:00"
                        horaSelect.appendChild(option);
                    });
                    horaSelect.disabled = false;
                } else {
                    horaSelect.innerHTML = '<option value="">No hay horarios disponibles</option>';
                    horaSelect.disabled = true;
                }
            } catch (error) {
                console.error('Error cargando horarios:', error);
                horaSelect.innerHTML = '<option value="">Error al cargar horarios</option>';
                horaSelect.disabled = true;
            }
        }        // ============================================
        // Listado de citas
        // ============================================
        async function cargarProximasCitas() {
            try {
                const response = await fetch(`/api/citas?estado=pendiente&estado=confirmada&pageSize=10`);
                const result = await response.json();

                if (result.success && result.data.items) {
                    const container = document.getElementById('listaCitas');
                    if (result.data.items.length === 0) {
                        container.innerHTML = '<div class="p-8 text-center text-gray-500">No hay citas próximas</div>';
                        return;
                    }

                    container.innerHTML = result.data.items.map(cita => {
                        const fecha = new Date(cita.fechaHoraInicio);
                        return `
                            <div class="p-4 hover:bg-gray-50 cursor-pointer transition" onclick="verDetalleCita(${cita.id})">
                                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3">
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <span class="font-medium text-gray-900">${escapeHtml(cita.clienteNombre)}</span>
                                            <span class="px-2 py-1 text-xs rounded-full ${getEstadoClase(cita.estado)}">${getEstadoTexto(cita.estado)}</span>
                                            ${cita.zonaCuerpo ? `<span class="px-2 py-1 text-xs rounded-full bg-purple-100 text-purple-700">📍 ${cita.zonaCuerpo}</span>` : ''}
                                        </div>
                                        <div class="text-sm text-gray-500 mt-1">
                                            📅 ${fecha.toLocaleDateString('es-ES')} - ${fecha.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' })}
                                            ${cita.tamanioCm ? ` | 📏 ${cita.tamanioCm} cm` : ''}
                                        </div>
                                        <div class="text-sm font-medium text-purple-600 mt-1">$${cita.precioTotal}</div>
                                    </div>
                                    <button class="text-purple-600 hover:text-purple-800 text-sm font-medium" onclick="event.stopPropagation(); verDetalleCita(${cita.id})">
                                        Ver detalles →
                                    </button>
                                </div>
                            </div>
                        `;
                    }).join('');
                }
            } catch (error) { console.error(error); }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        function getEstadoClase(estado) {
            const clases = { 'pendiente': 'bg-yellow-100 text-yellow-800', 'confirmada': 'bg-blue-100 text-blue-800', 'en_curso': 'bg-purple-100 text-purple-800', 'completada': 'bg-green-100 text-green-800' };
            return clases[estado] || 'bg-gray-100 text-gray-800';
        }

        function getEstadoTexto(estado) {
            const textos = { 'pendiente': 'Pendiente', 'confirmada': 'Confirmada', 'en_curso': 'En curso', 'completada': 'Completada' };
            return textos[estado] || estado;
        }

        // ============================================
        // Detalle de cita (SPA)
        // ============================================
        window.verDetalleCita = async function(id) {
            currentCitaId = id;
            const modal = document.getElementById('modalDetalle');
            const content = document.getElementById('detalleContent');

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            content.innerHTML = '<div class="text-center py-8">Cargando detalles...</div>';
            document.getElementById('btnCambiarEstado').classList.add('hidden');

            try {
                const response = await fetch(`/api/citas/${id}`);
                const result = await response.json();

                if (result.success) {
                    const cita = result.data;
                    const fechaInicio = new Date(cita.fechaHoraInicio);
                    const fechaFin = new Date(cita.fechaHoraFin);

                    let imagenHtml = '';
                    if (cita.fotoReferenciaUrl) {
                        imagenHtml = `
                            <div class="bg-gray-50 p-3 rounded-lg">
                                <p class="text-xs text-gray-500 mb-2">📷 Imagen de Referencia</p>
                                <img src="${cita.fotoReferenciaUrl}" class="w-full max-w-xs rounded-lg shadow-md cursor-pointer hover:opacity-90 transition" onclick="window.open('${cita.fotoReferenciaUrl}', '_blank')" alt="Referencia del diseño">
                            </div>
                        `;
                    }

                    content.innerHTML = `
                        <div class="space-y-4">
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Cliente</p>
                                    <p class="font-semibold">${escapeHtml(cita.clienteNombre)}</p>
                                    <p class="text-sm text-gray-600">${cita.clienteEmail || ''}</p>
                                    <p class="text-sm text-gray-600">${cita.clienteTelefono || ''}</p>
                                </div>
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Artista</p>
                                    <p class="font-semibold">${escapeHtml(cita.artistaNombre)}</p>
                                </div>
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Fecha y Hora</p>
                                    <p class="font-semibold">${fechaInicio.toLocaleDateString('es-ES')}</p>
                                    <p class="text-sm">${fechaInicio.toLocaleTimeString('es-ES')} - ${fechaFin.toLocaleTimeString('es-ES')}</p>
                                </div>
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Estado</p>
                                    <span class="px-2 py-1 text-xs rounded-full ${getEstadoClase(cita.estado)}">${getEstadoTexto(cita.estado)}</span>
                                </div>
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Zona del Cuerpo</p>
                                    <p class="font-semibold">${cita.zonaCuerpo || 'No especificada'}</p>
                                    ${cita.tamanioCm ? `<p class="text-sm text-gray-600">📏 ${cita.tamanioCm} cm</p>` : ''}
                                </div>
                                <div class="bg-gray-50 p-3 rounded-lg">
                                    <p class="text-xs text-gray-500">Precio</p>
                                    <p class="font-semibold text-green-600">$${cita.precioTotal}</p>
                                    <p class="text-sm text-gray-500">Adelanto: $${cita.adelanto}</p>
                                    <p class="text-sm font-medium">Saldo: $${cita.saldoPendiente}</p>
                                </div>
                            </div>
                            ${imagenHtml}
                            ${cita.notasInternas ? `<div class="bg-gray-50 p-3 rounded-lg"><p class="text-xs text-gray-500">Notas Internas</p><p class="text-sm">${escapeHtml(cita.notasInternas)}</p></div>` : ''}
                        </div>
                    `;

                    if (!['completada', 'cancelada'].includes(cita.estado)) {
                        const btn = document.getElementById('btnCambiarEstado');
                        btn.classList.remove('hidden');

                        const estadosSiguientes = {
                            'pendiente': { texto: 'Confirmar Cita', nuevoEstado: 'confirmada', color: 'bg-blue-600' },
                            'confirmada': { texto: 'Iniciar Sesión', nuevoEstado: 'en_curso', color: 'bg-purple-600' },
                            'en_curso': { texto: 'Completar Tatuaje', nuevoEstado: 'completada', color: 'bg-green-600' }
                        };

                        const siguiente = estadosSiguientes[cita.estado];
                        if (siguiente) {
                            btn.textContent = siguiente.texto;
                            btn.className = `px-4 py-2 ${siguiente.color} hover:${siguiente.color.replace('600', '700')} text-white rounded-lg transition font-medium`;
                            btn.onclick = () => cambiarEstadoCita(cita.id, siguiente.nuevoEstado);
                        }
                    }
                } else {
                    content.innerHTML = '<div class="text-center py-8 text-red-500">Error al cargar los detalles</div>';
                }
            } catch (error) {
                content.innerHTML = '<div class="text-center py-8 text-red-500">Error de conexión</div>';
            }
        };

        async function cambiarEstadoCita(id, nuevoEstado) {
            try {
                const response = await fetch(`/api/citas/${id}/estado`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ estado: nuevoEstado })
                });
                const result = await response.json();

                if (result.success) {
                    showToast(`Cita ${getEstadoTexto(nuevoEstado).toLowerCase()}`, 'success');
                    cerrarModalDetalle();
                    if (calendar) calendar.refetchEvents();
                    cargarProximasCitas();
                } else {
                    showToast(result.message || 'Error al cambiar estado', 'error');
                }
            } catch (error) {
                showToast('Error de conexión', 'error');
            }
        }

        window.cerrarModalDetalle = function() {
            const modal = document.getElementById('modalDetalle');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            currentCitaId = null;
        };

        // ============================================
        // Modal Crear Cita
        // ============================================
        window.abrirModalCrear = function() {
            const modal = document.getElementById('modalCrear');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.getElementById('formCita').reset();
            selectedZonaId = null;
            document.getElementById('zonaSeleccionada').classList.add('hidden');
            document.getElementById('zonaCuerpoId').value = '';
            document.getElementById('horaCita').disabled = true;
            document.getElementById('horaCita').innerHTML = '<option value="">Primero selecciona fecha</option>';
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('fechaCita').min = today;
            cargarUsuarioActual();
        };

        window.cerrarModalCrear = function() {
            const modal = document.getElementById('modalCrear');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        };

        window.guardarCita = async function() {
            const clienteId = document.getElementById('clienteId').value;
            const artistaId = document.getElementById('artistaId').value;
            const fecha = document.getElementById('fechaCita').value;
            let horaInicio = document.getElementById('horaCita').value;
            const duracion = parseInt(document.getElementById('duracion').value);
            const fotoReferencia = document.getElementById('fotoReferencia').files[0];

            // Logs para depuración
            console.log('Valores capturados:', { clienteId, artistaId, fecha, horaInicio, duracion, selectedZonaId });

            // Validaciones básicas
            if (!clienteId) { showToast('Selecciona un cliente', 'error'); return; }
            if (!artistaId) { showToast('Error: No se pudo identificar al artista', 'error'); return; }
            if (!fecha) { showToast('Selecciona una fecha', 'error'); return; }
            if (!horaInicio) { showToast('Selecciona una hora', 'error'); return; }
            if (!selectedZonaId) { showToast('Selecciona la zona del cuerpo', 'error'); return; }

            // Validar que la fecha no sea pasada
            const fechaSeleccionada = new Date(fecha);
            const hoy = new Date();
            hoy.setHours(0, 0, 0, 0);

            if (fechaSeleccionada < hoy) {
                showToast('No se pueden agendar citas en fechas pasadas', 'error');
                return;
            }

            // Limpiar el formato de hora - esperamos algo como "09:00"
            // Si viene con formato raro, extraer solo los primeros 5 caracteres
            if (horaInicio && horaInicio.length > 5) {
                horaInicio = horaInicio.substring(0, 5);
            }

            // Asegurar que tenga formato HH:MM
            if (horaInicio && !horaInicio.includes(':')) {
                horaInicio = `${horaInicio.padStart(2, '0')}:00`;
            }

            console.log('Hora formateada:', horaInicio);

            const fechaHoraInicioStr = `${fecha}T${horaInicio}`;
            console.log('fechaHoraInicioStr:', fechaHoraInicioStr);

            const fechaHoraInicio = new Date(fechaHoraInicioStr);
            console.log('fechaHoraInicio objeto:', fechaHoraInicio);

            // Validar que la fecha sea válida
            if (isNaN(fechaHoraInicio.getTime())) {
                showToast(`Formato de fecha/hora inválido: ${fechaHoraInicioStr}`, 'error');
                return;
            }

            const fechaHoraFin = new Date(fechaHoraInicio.getTime() + duracion * 60 * 60 * 1000);

            if (fechaHoraFin <= fechaHoraInicio) {
                showToast('La hora de fin debe ser posterior a la hora de inicio', 'error');
                return;
            }

            const formData = new FormData();
            formData.append('UsuarioId', clienteId);
            formData.append('ArtistaReferenciaId', artistaId);
            formData.append('FechaHoraInicio', fechaHoraInicio.toISOString());
            formData.append('FechaHoraFin', fechaHoraFin.toISOString());
            formData.append('PrecioTotal', document.getElementById('precioTotal').value || '0');
            formData.append('Adelanto', document.getElementById('adelanto').value || '0');
            formData.append('ZonaCuerpoId', selectedZonaId);
            formData.append('TamanioCm', document.getElementById('tamanioCm').value || '0');
            formData.append('NotasInternas', document.getElementById('notasInternas').value);
            formData.append('RequiereRecordatorio', document.getElementById('requiereRecordatorio').checked);

            if (fotoReferencia) {
                formData.append('FotoReferencia', fotoReferencia);
            }

            const btn = document.getElementById('btnGuardar');
            btn.disabled = true;
            btn.innerHTML = '<svg class="w-5 h-5 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Guardando...';

            try {
                const response = await fetch('/api/citas', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();

                if (result.success) {
                    showToast('Cita agendada exitosamente', 'success');
                    cerrarModalCrear();
                    if (calendar) calendar.refetchEvents();
                    cargarProximasCitas();
                } else {
                    showToast(result.message || 'Error al crear la cita', 'error');
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error de conexión con el servidor', 'error');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Guardar Cita';
            }
        };        document.getElementById('fotoReferencia')?.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(event) {
                    const preview = document.getElementById('previewImagen');
                    const img = document.getElementById('previewImg');
                    img.src = event.target.result;
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        });

        function limpiarImagen() {
            document.getElementById('fotoReferencia').value = '';
            document.getElementById('previewImagen').classList.add('hidden');
            document.getElementById('previewImg').src = '';
        }
    </script>
}