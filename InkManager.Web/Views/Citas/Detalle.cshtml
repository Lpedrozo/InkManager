@{
    ViewData["Title"] = "Detalle de Cita";
    var citaId = ViewBag.CitaId;
}

<div id="detalleContainer">
    <div class="text-center py-8">Cargando detalles...</div>
</div>

@section Scripts {
    <script>
        const citaId = @citaId;

        async function cargarDetalle() {
            try {
                const response = await fetch(`/api/citas/${citaId}`);
                const result = await response.json();

                if (result.success) {
                    renderizarDetalle(result.data);
                    cargarHistorialPagos();
                } else {
                    document.getElementById('detalleContainer').innerHTML = '<div class="text-center py-8 text-red-500">Error al cargar la cita</div>';
                }
            } catch (error) {
                console.error('Error:', error);
            }
        }

        function renderizarDetalle(cita) {
            const fechaInicio = new Date(cita.fechaHoraInicio);
            const fechaFin = new Date(cita.fechaHoraFin);

            const getEstadoBadge = (estado) => {
                const badges = {
                    'pendiente': '<span class="px-3 py-1 text-sm rounded-full bg-yellow-100 text-yellow-800">Pendiente</span>',
                    'confirmada': '<span class="px-3 py-1 text-sm rounded-full bg-blue-100 text-blue-800">Confirmada</span>',
                    'en_curso': '<span class="px-3 py-1 text-sm rounded-full bg-purple-100 text-purple-800">En curso</span>',
                    'completada': '<span class="px-3 py-1 text-sm rounded-full bg-green-100 text-green-800">Completada</span>',
                    'cancelada': '<span class="px-3 py-1 text-sm rounded-full bg-red-100 text-red-800">Cancelada</span>'
                };
                return badges[estado] || estado;
            };

            const html = `
                <div class="mb-6">
                    <a href="/Citas" class="text-blue-600 hover:text-blue-800">← Volver a mis citas</a>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Información principal -->
                    <div class="lg:col-span-2 space-y-6">
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <div class="flex justify-between items-start mb-4">
                                <h2 class="text-xl font-bold text-gray-800">Información de la Cita</h2>
                                ${getEstadoBadge(cita.estado)}
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-sm text-gray-500">Cliente</label>
                                    <p class="font-medium">${cita.clienteNombre}</p>
                                    <p class="text-sm text-gray-600">📧 ${cita.clienteEmail}</p>
                                    <p class="text-sm text-gray-600">📞 ${cita.clienteTelefono}</p>
                                </div>
                                <div>
                                    <label class="text-sm text-gray-500">Artista</label>
                                    <p class="font-medium">${cita.artistaNombre}</p>
                                </div>
                                <div>
                                    <label class="text-sm text-gray-500">Fecha y Hora</label>
                                    <p class="font-medium">${fechaInicio.toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}</p>
                                    <p class="text-sm text-gray-600">${fechaInicio.toLocaleTimeString('es-ES')} - ${fechaFin.toLocaleTimeString('es-ES')}</p>
                                    <p class="text-sm text-gray-500">Duración: ${Math.round((fechaFin - fechaInicio) / 1000 / 60)} minutos</p>
                                </div>
                                <div>
                                    <label class="text-sm text-gray-500">Zona del Cuerpo</label>
                                    <p class="font-medium">${cita.zonaCuerpo || 'No especificada'}</p>
                                    ${cita.tamanioCm ? `<p class="text-sm text-gray-600">📏 ${cita.tamanioCm} cm</p>` : ''}
                                </div>
                            </div>

                            ${cita.fotoReferenciaUrl ? `
                            <div class="mt-4">
                                <label class="text-sm text-gray-500">Foto de Referencia</label>
                                <div class="mt-2">
                                    <img src="${cita.fotoReferenciaUrl}" class="max-w-xs rounded-lg shadow" alt="Referencia">
                                </div>
                            </div>
                            ` : ''}

                            ${cita.notasInternas ? `
                            <div class="mt-4">
                                <label class="text-sm text-gray-500">Notas Internas</label>
                                <p class="mt-1 text-gray-700 bg-gray-50 p-3 rounded-lg">${cita.notasInternas}</p>
                            </div>
                            ` : ''}
                        </div>

                        <!-- Historial de estados -->
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">Historial de Estados</h3>
                            <div id="historialEstados" class="space-y-3">
                                <div class="text-center text-gray-500">Cargando historial...</div>
                            </div>
                        </div>
                    </div>

                    <!-- Sidebar -->
                    <div class="space-y-6">
                        <!-- Información financiera -->
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">💰 Información Financiera</h3>
                            <div class="space-y-3">
                                <div class="flex justify-between">
                                    <span class="text-gray-600">Precio Total:</span>
                                    <span class="font-bold text-gray-800">$${cita.precioTotal}</span>
                                </div>
                                <div class="flex justify-between">
                                    <span class="text-gray-600">Adelanto:</span>
                                    <span class="text-green-600">-$${cita.adelanto}</span>
                                </div>
                                <div class="border-t pt-2">
                                    <div class="flex justify-between">
                                        <span class="font-semibold">Saldo Pendiente:</span>
                                        <span class="font-bold text-blue-600">$${cita.saldoPendiente}</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-4">
                                <button onclick="abrirModalPago()" class="w-full bg-green-600 hover:bg-green-700 text-white font-semibold py-2 rounded-lg transition">
                                    Registrar Pago
                                </button>
                            </div>
                        </div>

                        <!-- Pagos registrados -->
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">📋 Pagos Registrados</h3>
                            <div id="listaPagos" class="space-y-2">
                                <div class="text-center text-gray-500">No hay pagos registrados</div>
                            </div>
                        </div>

                        <!-- Acciones rápidas -->
                        <div class="bg-white rounded-xl shadow-sm p-6">
                            <h3 class="text-lg font-semibold text-gray-800 mb-4">⚡ Acciones Rápidas</h3>
                            <div class="space-y-2">
                                ${cita.estado === 'pendiente' ? `
                                    <button onclick="cambiarEstado('confirmada')" class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded-lg transition">
                                        Confirmar Cita
                                    </button>
                                ` : ''}
                                ${cita.estado === 'confirmada' ? `
                                    <button onclick="cambiarEstado('en_curso')" class="w-full bg-purple-600 hover:bg-purple-700 text-white py-2 rounded-lg transition">
                                        Iniciar Sesión
                                    </button>
                                ` : ''}
                                ${cita.estado === 'en_curso' ? `
                                    <button onclick="cambiarEstado('completada')" class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded-lg transition">
                                        Completar Tatuaje
                                    </button>
                                ` : ''}
                                ${cita.estado !== 'cancelada' && cita.estado !== 'completada' ? `
                                    <button onclick="cancelarCita()" class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded-lg transition">
                                        Cancelar Cita
                                    </button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                </div>
            `;

            document.getElementById('detalleContainer').innerHTML = html;
        }

        async function cargarHistorialPagos() {
            try {
                const response = await fetch(`/api/citas/${citaId}/pagos`);
                const result = await response.json();

                if (result.success && result.data.length > 0) {
                    let html = '';
                    result.data.forEach(pago => {
                        html += `
                            <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                                <div>
                                    <p class="font-medium text-green-600">+$${pago.monto}</p>
                                    <p class="text-xs text-gray-500">${new Date(pago.fechaPago).toLocaleDateString()}</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-sm">${pago.metodoPagoDisplay}</p>
                                    ${pago.referenciaPago ? `<p class="text-xs text-gray-500">Ref: ${pago.referenciaPago}</p>` : ''}
                                </div>
                            </div>
                        `;
                    });
                    document.getElementById('listaPagos').innerHTML = html;
                } else {
                    document.getElementById('listaPagos').innerHTML = '<div class="text-center text-gray-500">No hay pagos registrados</div>';
                }
            } catch (error) {
                console.error('Error cargando pagos:', error);
            }
        }

        async function cambiarEstado(nuevoEstado) {
            const result = await Swal.fire({
                title: '¿Cambiar estado?',
                text: `¿Deseas cambiar el estado a "${nuevoEstado}"?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Sí, cambiar'
            });

            if (result.isConfirmed) {
                try {
                    const response = await fetch(`/api/citas/${citaId}/estado`, {
                        method: 'PATCH',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ estado: nuevoEstado })
                    });

                    const data = await response.json();

                    if (data.success) {
                        Swal.fire('Actualizado', 'Estado actualizado correctamente', 'success');
                        cargarDetalle();
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'Ocurrió un error', 'error');
                }
            }
        }

        async function cancelarCita() {
            const { value: motivo } = await Swal.fire({
                title: 'Cancelar Cita',
                text: 'Ingresa el motivo de cancelación',
                input: 'textarea',
                inputPlaceholder: 'Motivo de cancelación...',
                showCancelButton: true,
                confirmButtonText: 'Cancelar Cita',
                confirmButtonColor: '#d33'
            });

            if (motivo) {
                try {
                    const response = await fetch(`/api/citas/${citaId}/cancelar`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(motivo)
                    });

                    const data = await response.json();

                    if (data.success) {
                        Swal.fire('Cancelada', 'La cita ha sido cancelada', 'success');
                        cargarDetalle();
                    } else {
                        Swal.fire('Error', data.message, 'error');
                    }
                } catch (error) {
                    Swal.fire('Error', 'Ocurrió un error', 'error');
                }
            }
        }

        function abrirModalPago() {
            Swal.fire({
                title: 'Registrar Pago',
                html: `
                    <input type="number" id="monto" class="swal2-input" placeholder="Monto" step="0.01">
                    <select id="metodoPago" class="swal2-select">
                        <option value="efectivo">Efectivo</option>
                        <option value="tarjeta">Tarjeta</option>
                        <option value="transferencia">Transferencia</option>
                        <option value="otro">Otro</option>
                    </select>
                    <input type="text" id="referencia" class="swal2-input" placeholder="Referencia (opcional)">
                    <textarea id="nota" class="swal2-textarea" placeholder="Nota (opcional)"></textarea>
                `,
                showCancelButton: true,
                confirmButtonText: 'Registrar',
                preConfirm: () => {
                    const monto = document.getElementById('monto').value;
                    const metodoPago = document.getElementById('metodoPago').value;
                    const referencia = document.getElementById('referencia').value;
                    const nota = document.getElementById('nota').value;

                    if (!monto || parseFloat(monto) <= 0) {
                        Swal.showValidationMessage('Ingresa un monto válido');
                        return false;
                    }

                    return { monto: parseFloat(monto), metodoPago, referencia, nota };
                }
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const response = await fetch(`/api/citas/${citaId}/pagos`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(result.value)
                        });

                        const data = await response.json();

                        if (data.success) {
                            Swal.fire('Registrado', 'Pago registrado correctamente', 'success');
                            cargarDetalle();
                        } else {
                            Swal.fire('Error', data.message, 'error');
                        }
                    } catch (error) {
                        Swal.fire('Error', 'Ocurrió un error', 'error');
                    }
                }
            });
        }

        // Inicializar
        cargarDetalle();
    </script>
}